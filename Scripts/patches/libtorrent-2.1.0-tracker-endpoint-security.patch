+TORRENT_TEST(https_http_proxy_connect_uses_vetted_numeric_endpoint)
+{
+#if TORRENT_USE_SSL
+	io_context ios;
+	tcp::acceptor proxy_acceptor(ios
+		, tcp::endpoint(address_v4::loopback(), 0));
+	tcp::socket proxy_socket(ios);
+	std::string proxy_request;
+	bool received_connect = false;
+	aux::deadline_timer watchdog(ios);
+
+	proxy_acceptor.async_accept(proxy_socket
+		, [&](error_code const& accept_error)
+		{
+			if (accept_error) return;
+			boost::asio::async_read_until(proxy_socket
+				, boost::asio::dynamic_buffer(proxy_request, 4096), "\r\n\r\n"
+				, [&](error_code const& read_error, std::size_t)
+				{
+					if (read_error) return;
+					received_connect = true;
+					watchdog.cancel();
+					auto response = std::make_shared<std::string>(
+						"HTTP/1.1 502 Bad Gateway\r\n"
+						"Content-Length: 0\r\nConnection: close\r\n\r\n");
+					boost::asio::async_write(proxy_socket
+						, boost::asio::buffer(*response)
+						, [&, response](error_code const&, std::size_t)
+						{
+							error_code ignored;
+							proxy_socket.close(ignored);
+						});
+				});
+		});
+
+	watchdog.expires_after(seconds(5));
+	watchdog.async_wait([&](error_code const& error)
+	{
+		if (error) return;
+		error_code ignored;
+		proxy_acceptor.close(ignored);
+		proxy_socket.close(ignored);
+	});
+
+	aux::session_settings sett;
+	sett.set_bool(settings_pack::ssrf_mitigation, true);
+	sett.set_int(settings_pack::tracker_completion_timeout, 3);
+	sett.set_int(settings_pack::proxy_type, settings_pack::http);
+	sett.set_str(settings_pack::proxy_hostname, "127.0.0.1");
+	sett.set_int(settings_pack::proxy_port, proxy_acceptor.local_endpoint().port());
+	sett.set_bool(settings_pack::proxy_tracker_connections, true);
+	sett.set_bool(settings_pack::proxy_send_host_in_connect, true);
+	scripted_resolver resolver{ios};
+	resolver.results["ipv4only.arpa"] = {
+		make_address("192.0.0.170"), make_address("192.0.0.171")};
+	resolver.results["tracker.test"] = {make_address("8.8.8.8")};
+	tracker_manager_handler h{ios, sett, resolver};
+	auto const socket = internet_socket_v4();
+	auto callback = std::make_shared<ws_request_callback>();
+	aux::ssl::context ssl_context(aux::ssl::context::sslv23_client);
+	auto request = tracker_request_for("https://tracker.test:443/announce", socket);
+	request.ssl_ctx = &ssl_context;
+
+	h.m_tracker_manager.queue_request(ios, std::move(request), sett, callback);
+	ios.run();
+
+	TEST_CHECK(received_connect);
+	TEST_CHECK(proxy_request.rfind("CONNECT 8.8.8.8:443 HTTP/1.0\r\n", 0) == 0);
+	TEST_CHECK(proxy_request.find("tracker.test") == std::string::npos);
+	TEST_EQUAL(callback->error_count, 1);
+#else
+	TEST_CHECK(true);
+#endif
+}
