+TORRENT_TEST(http_tracker_preflight_timer_stops_before_http_request)
+{
+#if TORRENT_USE_SSL
+	io_context ios;
+	tcp::acceptor proxy_acceptor(ios
+		, tcp::endpoint(address_v4::loopback(), 0));
+	tcp::socket proxy_socket(ios);
+	std::string proxy_request;
+	std::atomic<bool> client_blocked{false};
+	std::atomic<bool> terminal_response_sent{false};
+
+	aux::session_settings sett;
+	sett.set_bool(settings_pack::ssrf_mitigation, true);
+	sett.set_int(settings_pack::tracker_completion_timeout, 1);
+	sett.set_int(settings_pack::proxy_type, settings_pack::http);
+	sett.set_str(settings_pack::proxy_hostname, "127.0.0.1");
+	sett.set_int(settings_pack::proxy_port, proxy_acceptor.local_endpoint().port());
+	sett.set_bool(settings_pack::proxy_tracker_connections, true);
+	scripted_resolver resolver{ios};
+	resolver.results["ipv4only.arpa"] = {
+		make_address("192.0.0.170"), make_address("192.0.0.171")};
+	resolver.results["tracker.test"] = {make_address("8.8.8.8")};
+	tracker_manager_handler h{ios, sett, resolver};
+	auto const socket = internet_socket_v4();
+	auto callback = std::make_shared<ws_request_callback>();
+	aux::ssl::context ssl_context(aux::ssl::context::sslv23_client);
+	auto request = tracker_request_for("https://tracker.test:443/announce", socket);
+	request.ssl_ctx = &ssl_context;
+
+	// Hold the client event loop across the former preflight deadline after the
+	// proxy has a terminal response ready. With two independent request timers,
+	// the response and both deadlines become ready together and may enqueue two
+	// tracker failures. A preflight-only timer has already been cancelled, so the
+	// HTTP connection remains the sole owner of request completion.
+	auto const former_preflight_deadline = clock_type::now() + seconds(1);
+	std::thread proxy_thread([&]
+	{
+		error_code error;
+		proxy_acceptor.accept(proxy_socket, error);
+		if (error) return;
+		boost::asio::read_until(proxy_socket
+			, boost::asio::dynamic_buffer(proxy_request, 4096), "\r\n\r\n", error);
+		if (error) return;
+
+		post(ios, [&]
+		{
+			client_blocked.store(true, std::memory_order_release);
+			std::this_thread::sleep_until(
+				former_preflight_deadline + milliseconds(200));
+		});
+		while (!client_blocked.load(std::memory_order_acquire))
+			std::this_thread::yield();
+
+		std::string const response =
+			"HTTP/1.1 502 Bad Gateway\r\n"
+			"Content-Length: 0\r\nConnection: close\r\n\r\n";
+		boost::asio::write(proxy_socket, boost::asio::buffer(response), error);
+		terminal_response_sent.store(!error, std::memory_order_release);
+		proxy_socket.close(error);
+	});
+
+	h.m_tracker_manager.queue_request(ios, std::move(request), sett, callback);
+	ios.run();
+	proxy_thread.join();
+
+	TEST_CHECK(terminal_response_sent.load(std::memory_order_acquire));
+	TEST_CHECK(std::find(resolver.lookups.begin(), resolver.lookups.end()
+		, "ipv4only.arpa") != resolver.lookups.end());
+	TEST_EQUAL(callback->error_count, 1);
+	TEST_CHECK(h.m_tracker_manager.empty());
+#else
+	TEST_CHECK(true);
+#endif
+}
