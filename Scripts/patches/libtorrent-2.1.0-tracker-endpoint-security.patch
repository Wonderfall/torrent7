+	resolver.results["ipv4only.arpa"] = {
+		make_address("192.0.0.170"), make_address("192.0.0.171")};
+	// The IPv6 endpoint cannot route through this IPv4 socket, but it must be
+	// classified as SSRF before the address-family reachability check.
+	resolver.results["private.test"] = {make_address("fd00::20")};
+	tracker_manager_handler h{ios, sett, resolver};
+	auto const socket = internet_socket_v4();
+	auto callback = std::make_shared<ws_request_callback>();
+
+	h.m_tracker_manager.queue_request(ios
+		, tracker_request_for("http://private.test:8080/announce", socket)
+		, sett, callback);
+	ios.run();
+
+	TEST_EQUAL(callback->error_count, 1);
+	TEST_EQUAL(callback->last_error, error_code(errors::ssrf_mitigation));
+	TEST_CHECK(callback->last_operation == operation_t::bittorrent);
+}
