+struct scripted_resolver : aux::resolver_interface
+{
+	explicit scripted_resolver(io_context& ios) : m_ios(ios) {}
+
+	void async_resolve(std::string const& host, aux::resolver_flags
+		, callback_t handler) override
+	{
+		lookups.push_back(host);
+		if (stalled.count(host) != 0)
+		{
+			pending.push_back(std::move(handler));
+			return;
+		}
+		auto const found = results.find(host);
+		if (found == results.end())
+		{
+			post(m_ios, [handler = std::move(handler)]
+			{
+				handler(error_code(boost::asio::error::host_not_found), {});
+			});
+			return;
+		}
+
+		std::vector<address> addresses = found->second;
+		post(m_ios, [handler = std::move(handler), addresses = std::move(addresses)]
+			{ handler(error_code{}, addresses); });
+	}
+
+	void abort() override {}
+	void set_cache_timeout(seconds) override {}
+	void complete_stalled()
+	{
+		auto callbacks = std::move(pending);
+		for (auto& callback : callbacks)
+		{
+			post(m_ios, [callback = std::move(callback)]
+				{ callback(error_code(boost::asio::error::operation_aborted), {}); });
+		}
+	}
+
+	io_context& m_ios;
+	std::map<std::string, std::vector<address>> results;
+	std::set<std::string> stalled;
+	std::vector<callback_t> pending;
+	std::vector<std::string> lookups;
 };
 
