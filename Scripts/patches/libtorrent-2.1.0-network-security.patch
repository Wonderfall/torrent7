+TORRENT_TEST(nat64_prefix_discovery)
+{
+	struct test_case
+	{
+		int length;
+		char const* discovery;
+		char const* private_target;
+		char const* global_target;
+	};
+
+	std::array<test_case, 6> const cases = {{
+		{32, "2001:4860:c000:aa::", "2001:4860:a00:1::1234", "2001:4860:808:808::"},
+		{40, "2001:4860:abc0:0:aa::", "2001:4860:ab0a:0:1::1234", "2001:4860:ab08:808:8::"},
+		{48, "2001:4860:abcd:c000:0:aa00::", "2001:4860:abcd:a00:0:100:0:1234", "2001:4860:abcd:808:8:800::"},
+		{56, "2001:4860:abcd:efc0:0:aa::", "2001:4860:abcd:ef0a:0:1:0:1234", "2001:4860:abcd:ef08:8:808::"},
+		{64, "2001:4860:abcd:ef01:c0:0:aa00:0", "2001:4860:abcd:ef01:a:0:100:1234", "2001:4860:abcd:ef01:8:808:800:0"},
+		{96, "2001:4860:abcd:ef01::c000:aa", "2001:4860:abcd:ef01::a00:1", "2001:4860:abcd:ef01::808:808"},
+	}};
+
+	for (test_case const& test : cases)
+	{
+		std::array<address, 1> const answers = {{make_address(test.discovery)}};
+		nat64_discovery_result const discovery = discover_nat64_prefixes(answers);
+		TEST_CHECK(discovery.valid);
+		TEST_EQUAL(discovery.prefixes.size(), 1);
+		if (discovery.prefixes.empty()) continue;
+		TEST_EQUAL(int(discovery.prefixes.front().length), test.length);
+		TEST_CHECK(!is_global(make_address(test.private_target), discovery.prefixes));
+		TEST_CHECK(is_global(make_address(test.global_target), discovery.prefixes));
+		TEST_CHECK(is_global(make_address("2606:4700:4700::1111"), discovery.prefixes));
+	}
+}
+
+TORRENT_TEST(nat64_discovery_fails_closed_on_malformed_answers)
+{
+	std::array<address, 2> const direct = {{
+		make_address("192.0.0.170"), make_address("192.0.0.171")}};
+	auto discovery = discover_nat64_prefixes(direct);
+	TEST_CHECK(discovery.valid);
+	TEST_CHECK(discovery.prefixes.empty());
+
+	std::array<address, 1> const well_known_prefix = {{
+		make_address("64:ff9b::c000:aa")}};
+	discovery = discover_nat64_prefixes(well_known_prefix);
+	TEST_CHECK(discovery.valid);
+	TEST_EQUAL(discovery.prefixes.size(), 1);
+
+	std::array<address, 2> const unexpected_v4 = {{
+		make_address("192.0.0.170"), make_address("8.8.8.8")}};
+	discovery = discover_nat64_prefixes(unexpected_v4);
+	TEST_CHECK(!discovery.valid);
+
+	std::array<address, 2> const mixed_v6 = {{
+		make_address("2001:4860:c000:aa::"),
+		make_address("2606:4700:4700::1111")}};
+	discovery = discover_nat64_prefixes(mixed_v6);
+	TEST_CHECK(!discovery.valid);
+
+	// Bits 64-71 are part of this /96 NSP and violate RFC 6052 when nonzero.
+	std::array<address, 1> const malformed_96 = {{
+		make_address("2001:4860:abcd:ef01:100:0:c000:aa")}};
+	discovery = discover_nat64_prefixes(malformed_96);
+	TEST_CHECK(!discovery.valid);
+
+	std::array<address, 1> const non_global_prefix = {{
+		make_address("fd00:1234:5678:9abc::c000:aa")}};
+	discovery = discover_nat64_prefixes(non_global_prefix);
+	TEST_CHECK(!discovery.valid);
+
+	std::array<address, 0> const empty{};
+	discovery = discover_nat64_prefixes(empty);
+	TEST_CHECK(!discovery.valid);
+}
