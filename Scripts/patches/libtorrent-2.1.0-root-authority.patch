+void test_descriptor_backed_root_replacement(bool const replace_with_symlink)
+{
+	std::string const suffix = replace_with_symlink ? "symlink" : "directory";
+	std::string const root = complete("descriptor-root-" + suffix);
+	std::string const retained = complete("descriptor-retained-" + suffix);
+	std::string const replacement = complete("descriptor-replacement-" + suffix);
+	error_code ec;
+	remove_all(root, ec);
+	ec.clear();
+	remove_all(retained, ec);
+	ec.clear();
+	remove_all(replacement, ec);
+	ec.clear();
+	create_directories(root, ec);
+	TEST_CHECK(!ec);
+	create_directories(replacement, ec);
+	TEST_CHECK(!ec);
+	touch_file(combine_path(root, "owned"), 16);
+	touch_file(combine_path(replacement, "decoy"), 32);
+
+	int const borrowed = ::open(root.c_str(), O_RDONLY | O_DIRECTORY | O_NOFOLLOW | O_CLOEXEC);
+	TEST_CHECK(borrowed >= 0);
+	struct ::stat metadata {};
+	TEST_EQUAL(::fstat(borrowed, &metadata), 0);
+	auto authority = aux::make_storage_root(
+		root, borrowed
+		, static_cast<std::uint64_t>(metadata.st_dev)
+		, static_cast<std::uint64_t>(metadata.st_ino)
+		, std::make_shared<int>(1), ec);
+	TEST_CHECK(!ec);
+	TEST_CHECK(bool(authority));
+	TEST_EQUAL(::close(borrowed), 0);
+
+	rename(root, retained, ec);
+	TEST_CHECK(!ec);
+	if (replace_with_symlink)
+	{
+		TEST_EQUAL(::symlink(replacement.c_str(), root.c_str()), 0);
+	}
+	else
+	{
+		create_directories(root, ec);
+		TEST_CHECK(!ec);
+	}
+	touch_file(combine_path(replace_with_symlink ? replacement : root, "decoy"), 32);
+
+	confined_create_directories(root, "nested", ec, authority);
+	TEST_CHECK(!ec);
+	{
+		aux::file_handle file(root, "nested/data", 8
+			, aux::open_mode::write | aux::open_mode::truncate, authority);
+	}
+	TEST_CHECK(exists(combine_path(retained, "nested/data"), ec));
+	TEST_CHECK(!ec);
+	TEST_CHECK(!exists(combine_path(replacement, "nested/data"), ec));
+	TEST_CHECK(!ec);
+	if (!replace_with_symlink)
+	{
+		TEST_CHECK(!exists(combine_path(root, "nested/data"), ec));
+		TEST_CHECK(!ec);
+	}
+
+	confined_remove(root, "owned", false, ec, authority);
+	TEST_CHECK(!ec);
+	TEST_CHECK(!exists(combine_path(retained, "owned"), ec));
+	TEST_CHECK(!ec);
+	confined_remove(root, "decoy", false, ec, authority);
+	TEST_CHECK(ec == boost::system::errc::no_such_file_or_directory);
+	ec.clear();
+	std::string const replacement_path = replace_with_symlink ? replacement : root;
+	TEST_CHECK(exists(combine_path(replacement_path, "decoy"), ec));
+	TEST_CHECK(!ec);
+
+	if (replace_with_symlink)
+	{
+		remove(root, ec);
+		TEST_CHECK(!ec);
+	}
+	else
+	{
+		remove_all(root, ec);
+		TEST_CHECK(!ec);
+	}
+	confined_create_directories(root, "after-missing", ec, authority);
+	TEST_CHECK(!ec);
+	TEST_CHECK(!exists(root, ec));
+	TEST_CHECK(!ec);
+	TEST_CHECK(exists(combine_path(retained, "after-missing"), ec));
+	TEST_CHECK(!ec);
+
+	remove_all(retained, ec);
+	TEST_CHECK(!ec);
+	remove_all(replacement, ec);
+	TEST_CHECK(!ec);
+}
+
+} // anonymous namespace
+
+TORRENT_TEST(descriptor_backed_root_rejects_symlink_replacement)
+{
+	test_descriptor_backed_root_replacement(true);
+}
+
+TORRENT_TEST(descriptor_backed_root_rejects_directory_replacement)
+{
+	test_descriptor_backed_root_replacement(false);
